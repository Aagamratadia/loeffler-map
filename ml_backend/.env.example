# ML Backend Service Configuration
# This file contains configuration for deploying the ML model backend

# Environment Variables
MODEL_PATH=models/antihypertensive_model.pkl
PORT=8000
LOG_LEVEL=info

# Data source (for training)
TRAINING_DATA_PATH=/data/antihypertensive_dataset_expanded.csv

# CORS settings
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Production settings
DEBUG=false
